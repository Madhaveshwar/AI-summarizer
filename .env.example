# Example environment variables for AI Content Summarizer
# Copy this file to `.env` and replace placeholders with your own values.

# Groq API key used for content summarization requests.
# Get one from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional Groq model selection.
# Supported models in this project: llama-3.1-8b-instant, llama3-8b-8192, gemma-7b-it
GROQ_MODEL=llama-3.1-8b-instant

# LangSmith API key used to send traces to your LangSmith project.
# Get one from: https://smith.langchain.com/
LANGCHAIN_API_KEY=your_langsmith_api_key_here

# Enable LangSmith tracing for LangChain-compatible instrumentation.
LANGCHAIN_TRACING_V2=true

# LangSmith project name shown in the LangSmith dashboard.
LANGCHAIN_PROJECT=AI_Content_Summarizer
